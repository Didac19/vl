NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/via_libre

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=vialibre_dev_secret_key_2024_highly_secure
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=vialibre_refresh_dev_secret_key_2024
REFRESH_TOKEN_EXPIRES_IN=7d

# Ticketing
TICKET_SIGNING_SECRET=vialibre_ticket_signing_secret_offline_validation

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
